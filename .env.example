# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Abacus AI / RouteLLM ──────────────────────────────────────────
ABACUS_API_KEY=your_api_key_here
ABACUS_BASE_URL=https://routellm.abacus.ai/v1

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Data ─────────────────────────────────────────────────────────
SEED_CSV_PATH=Tortured_Phrases_Lexicon_2.csv
REPORTS_DIR=reports

# ── Limits ───────────────────────────────────────────────────────
MAX_PROMPT_MATCHES=300
LLM_TIMEOUT_SECS=18.0
DISCOVERY_TIMEOUT_SECS=45.0

# ── Features ─────────────────────────────────────────────────────
ENABLE_SINGLE_WORD_ANALYSIS=true
DISCOVERY_ENABLED=true
